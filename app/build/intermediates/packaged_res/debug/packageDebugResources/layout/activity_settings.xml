<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_bg"
    android:orientation="vertical">

    <!-- Header Estilo Android 14 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configurações"
            android:textColor="@color/settings_text_primary"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agente de Gerenciamento CityHub"
            android:textColor="@color/settings_text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp"
            android:visibility="gone">

            <!-- SEÇÃO: APARÊNCIA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aparência"
                android:textColor="@color/settings_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cor de fundo"
                    android:textColor="@color/settings_text_primary"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/etBgColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="#1A1A2E"
                    android:inputType="text"
                    android:paddingVertical="8dp"
                    android:textColor="@color/settings_accent"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10000000"
                    android:layout_marginVertical="12dp" />

                <CheckBox
                    android:id="@+id/cbLockWpEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Substituir Wallpaper da Lock Screen"
                    android:textColor="@color/settings_text_primary" />

                <TextView
                    android:id="@+id/tvLockWpApiWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aviso: Lock Screen customizada exige Android 7.0+"
                    android:textColor="#FF5252"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="32dp" />

                <TextView
                    android:id="@+id/tvLockWpImagePath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(usando cor de fundo)"
                    android:textColor="@color/settings_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginStart="32dp" />

                <ImageView
                    android:id="@+id/ivCurrentLockWp"
                    android:layout_width="120dp"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="32dp"
                    android:scaleType="centerCrop"
                    android:background="#20000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="32dp">

                    <Button
                        android:id="@+id/btnPickLockWpImage"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escolher"
                        android:textColor="@color/settings_accent"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnClearLockWpImage"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Redefinir"
                        android:textColor="@color/settings_text_secondary"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnApplyLockWpNow"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aplicar"
                        android:textColor="@color/settings_accent"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- SEÇÃO: SEGURANÇA E REGRAS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Segurança e Regras"
                android:textColor="@color/settings_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/cbBlockSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bloquear Configurações do Android"
                    android:textColor="@color/settings_text_primary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10000000"
                    android:layout_marginVertical="12dp" />

                <CheckBox
                    android:id="@+id/cbAutoStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Iniciar com o sistema (Boot)"
                    android:textColor="@color/settings_text_primary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10000000"
                    android:layout_marginVertical="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alterar Senha Admin"
                    android:textColor="@color/settings_text_primary"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/etAdminPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Nova senha"
                    android:inputType="textPassword"
                    android:paddingVertical="8dp"
                    android:textColor="@color/settings_accent"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etAdminPasswordConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Confirmar nova senha"
                    android:inputType="textPassword"
                    android:paddingVertical="8dp"
                    android:textColor="@color/settings_accent"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10000000"
                    android:layout_marginVertical="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Modo de Filtragem"
                    android:textColor="@color/settings_text_primary"
                    android:textSize="16sp" />

                <Spinner
                    android:id="@+id/spFilterMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/btnManageApps"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_manage_apps_label"
                    android:textColor="@color/settings_accent"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical" />
            </LinearLayout>

            <!-- SEÇÃO: SISTEMA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sistema"
                android:textColor="@color/settings_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvPermissionsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Permissões: Verificando..."
                    android:textColor="@color/settings_text_secondary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnRequestPermissions"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Corrigir permissões pendentes"
                    android:textColor="@color/settings_accent"
                    android:textAllCaps="false"
                    android:gravity="start|center_vertical" />
            </LinearLayout>

            <!-- Ações Finais -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:gravity="end">

                <Button
                    android:id="@+id/btnApply"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Testar"
                    android:textColor="@color/settings_text_secondary"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_button_primary"
                    android:paddingHorizontal="24dp"
                    android:text="Salvar Alterações"
                    android:textColor="@color/white"
                    android:textAllCaps="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
