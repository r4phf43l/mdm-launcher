    <!-- Opções de modo de filtro -->
    <string-array name="filter_mode_options">
        <item>Sem filtro (mostrar todos)</item>
        <item>Allowlist (mostrar apenas permitidos)</item>
        <item>Denylist (ocultar bloqueados)</item>
    </string-array>

    <string-array name="filter_mode_values">
        <item>none</item>
