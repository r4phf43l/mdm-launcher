    <string name="restriction_auto_start_description">Inicia o serviço de monitoramento automaticamente quando o dispositivo é ligado.</string>

    <string name="restriction_config_json_title">Configuração via JSON (Simplificada)</string>
    <string name="restriction_config_json_description">Permite enviar todas as configurações em um único campo JSON. Sobrescreve campos individuais se presente.</string>

    <string name="restriction_home_apps_title">Apps da Tela Inicial</string>
    <string name="restriction_home_apps_description">Lista de pacotes separados por vírgula para exibir como atalhos na tela inicial.</string>
    <string name="restriction_deeplink_list_title">Lista de Deeplinks para Execução</string>
    <string name="restriction_deeplink_list_description">Lista de URIs de deeplink separadas por vírgula para serem executadas automaticamente.</string>

    <string name="tab_all">Todos</string>
